# Supabase → Settings → Database → Connection string → URI (mode: transaction o session)
DATABASE_URL="postgresql://postgres:[password]@[host]:[port]/postgres"

# Secreto para firmar JWTs — genera uno largo y aleatorio (ej: openssl rand -hex 64)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Render lo inyecta automáticamente en producción; no hace falta definirlo localmente
# NODE_ENV=production
