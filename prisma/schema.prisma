generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RoutineType {
  id              Int        @id @default(autoincrement())
  category        String
  daysOfTheWeek   String     @map("days_of_the_week")
  description     String?
  exercises       Exercise[]

  @@map("routine_type")
}

model Exercise {
  id               Int           @id @default(autoincrement())
  name             String
  description      String?
  series           Int
  repetitions      Int
  muscleTags       String        @map("muscle_tags")
  routineTypeIdFk  Int?          @map("routine_type_id_fk")
  routineType      RoutineType?  @relation(fields: [routineTypeIdFk], references: [id])
  trainingLogs     TrainingLog[]

  @@map("exercises")
}

model TrainingLog {
  id               Int       @id @default(autoincrement())
  exerciseIdFk     Int?      @map("exercise_id_fk")
  exercise         Exercise? @relation(fields: [exerciseIdFk], references: [id])
  weightKg         Decimal?  @map("weight_kg") @db.Decimal(6, 2)
  repetitionsDone  Int       @map("repetitions_done")
  trainingDate     DateTime  @map("training_date") @db.Date
  startTime        DateTime? @map("start_time") @db.Time(6)
  endTime          DateTime? @map("end_time") @db.Time(6)
  exerciseDetails  Json      @map("exercise_details")

  @@map("training_logs")
}
